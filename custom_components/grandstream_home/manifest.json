{
  "domain": "grandstream_home",
  "name": "Grandstream Home",
  "codeowners": ["@GrandstreamEngineering"],
  "config_flow": true,
  "dependencies": [
    "camera",
    "stream",
    "ffmpeg",
    "lock",
    "webhook"
  ],
  "documentation": "https://github.com/GrandstreamEngineering/grandstream_home/blob/main/README.md",
  "integration_type": "device",
  "iot_class": "local_push",
  "issue_tracker": "https://github.com/GrandstreamEngineering/grandstream_home/issues",
  "requirements": ["grandstream-home-api==0.1.3"],
  "version": "1.0.1",
  "zeroconf": [
    { "type": "_https._tcp.local.", "name": "gds*" },
    { "type": "_https._tcp.local.", "name": "gsc*" },
    { "type": "_device-info._tcp.local.", "name": "*" }
  ]
}
